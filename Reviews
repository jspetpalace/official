
<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Reviews & Gallery - J’s Pet Palace</title>
<link href="https://fonts.googleapis.com" rel="stylesheet">

<style>
/* --- FIXED BORDER SCROLL --- */
.edge-banner { position: fixed; background: #000; z-index: 9999; overflow: hidden; white-space: nowrap; display: flex; align-items: center; }
.edge-top { top: 0; left: 0; width: 100%; height: 30px; }
.edge-bottom { bottom: 0; left: 0; width: 100%; height: 30px; }
.edge-left { top: 0; left: 0; width: 30px; height: 100%; writing-mode: vertical-rl; }
.edge-right { top: 0; right: 0; width: 30px; height: 100%; writing-mode: vertical-rl; }
.edge-banner span { font-size: 12px; color: white; text-shadow: 0 0 3px #fe14ca; padding-left: 100%; display: inline-block; animation: edgeScroll 25s linear infinite; }
@keyframes edgeScroll { 0% { transform: translateX(0); } 100% { transform: translateX(-100%); } }
.edge-left span, .edge-right span { animation: edgeScrollVertical 25s linear infinite; padding-top: 100%; padding-left: 0; }
@keyframes edgeScrollVertical { 0% { transform: translateY(0); } 100% { transform: translateY(-100%); } }

/* --- NAVBAR --- */
.navbar { position: fixed; top: 30px; width: 100%; background: rgba(0,0,0,0.95); border-bottom: 1px solid #fe14ca; z-index: 1000; height: 70px; display: flex; align-items: center; overflow-x: auto; white-space: nowrap; padding: 0 20px; -ms-overflow-style: none; scrollbar-width: none; }
.navbar::-webkit-scrollbar { display: none; }
.navbar a { display: inline-block; color: #fe14ca; text-decoration: none; padding: 10px 20px; border: 1px solid #fe14ca; border-radius: 6px; background: #111; margin: 0 10px; flex-shrink: 0; }

/* --- SHARED PAGE STYLES --- */
* { margin: 0; padding: 0; box-sizing: border-box; }
body { font-family: 'Cinzel Decorative', serif; color: #fff; background: #000; overflow-x: hidden; }
.container { padding-top: 160px; width: 90%; max-width: 800px; margin: auto; }

/* PINK GLOW BOXES */
.section-box { border: 1px solid #fe14ca; padding: 25px; margin: 30px auto; width: 75%; text-align: center; }
.section-box div { margin: 10px 0; font-size: 16px; text-shadow: 0 0 1px #fff, 0 0 3px #fe14ca; }

/* PLACEHOLDERS */
.placeholder { border: 2px dashed #fe14ca; background: rgba(255,255,255,0.05); display: flex; align-items: center; justify-content: center; color: #fe14ca; font-size: 14px; text-align: center; margin-bottom: 20px; }
.video-placeholder { height: 200px; width: 100%; margin-bottom: 20px; }
.image-placeholder { height: 300px; width: 100%; margin-bottom: 20px; }

/* FOOTER & BUTTON */
.footer { margin-top: 40px; text-align: center; padding: 20px; border-top: 1px solid #fe14ca; }
#topBtn { position: fixed; bottom: 40px; right: 40px; background: #fe14ca; color: black; border: none; padding: 12px; cursor: pointer; z-index: 10000; }
</style>
</head>

<body>

<!-- BORDER SCROLLS -->
<div class="edge-banner edge-top"><span>Welcome to J’s Pet Palace • Where Every Pet Feels Like Family • </span></div>
<div class="edge-banner edge-bottom"><span>Welcome to J’s Pet Palace • Where Every Pet Feels Like Family • </span></div>
<div class="edge-banner edge-left"><span>Welcome to J’s Pet Palace • Where Every Pet Feels Like Family • </span></div>
<div class="edge-banner edge-right"><span>Welcome to J’s Pet Palace • Where Every Pet Feels Like Family • </span></div>

<!-- NAV TABS -->
<div class="navbar">
    <a href="index.html">Home</a>
    <a href="booking.html">Booking, Grooming & DayCare</a>
    <a href="reviews.html">Reviews</a>
    <a href="about.html">Meet Your Groomer</a>
</div>

<div class="container">

    <!-- TOP PICTURE & BANNER PLACEHOLDERS -->
    <div style="text-align: center; margin-bottom: 20px;">
        <div class="placeholder" style="width: 320px; height: 200px; margin: auto;">Top Picture Placeholder</div>
    </div>
    <div class="placeholder" style="height: 160px; width: 100%;">Top Banner Placeholder</div>

    <!-- VIDEO GALLERY (6 VIDEOS) -->
    <div class="section-box">
        <div><strong>Watch Our Furry Clients</strong></div>
        <div class="placeholder video-placeholder">Video 1</div>
        <div class="placeholder video-placeholder">Video 2</div>
        <div class="placeholder video-placeholder">Video 3</div>
        <div class="placeholder video-placeholder">Video 4</div>
        <div class="placeholder video-placeholder">Video 5</div>
        <div class="placeholder video-placeholder">Video 6</div>
    </div>

    <!-- PHOTO GALLERY (6 PICTURES) -->
    <div class="section-box">
        <div><strong>Our Masterpieces</strong></div>
        <div class="placeholder image-placeholder">Picture 1</div>
        <div class="placeholder image-placeholder">Picture 2</div>
        <div class="placeholder image-placeholder">Picture 3</div>
        <div class="placeholder image-placeholder">Picture 4</div>
        <div class="placeholder image-placeholder">Picture 5</div>
        <div class="placeholder image-placeholder">Picture 6</div>
    </div>

    <!-- INSTAGRAM CALL TO ACTION -->
