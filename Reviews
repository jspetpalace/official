        <div style="font-size: 18px;"><strong>Please visit our Instagram page!</strong></div>
        <div style="font-size: 16px;">Leave reviews, tag us in your photos, and join the J's Pet Palace family!</div>
        
        <!-- INSTAGRAM FEED PLACEHOLDER -->
        <div class="placeholder" style="height: 400px; width: 100%; margin-top: 20px;">
            Instagram Page/Feed Placeholder
        </div>
    </div>

    <!-- BOTTOM PICTURE & BANNER PLACEHOLDERS -->
    <div style="text-align: center; margin-top: 20px;">
        <div class="placeholder" style="width: 300px; height: 150px; margin: auto;">Bottom Picture Placeholder</div>
    </div>
    <div class="placeholder" style="height: 90px; width: 100%;">Bottom Banner Placeholder</div>

</div>

<!-- FOOTER -->
<div class="footer">
    Instagram: [Insert Handle] | Facebook: [Insert Link]
</div>

<button onclick="topFunction()" id="topBtn">Top</button>

<script>
function topFunction() {
    window.scrollTo({ top: 0, behavior: 'smooth' });
}
</script>

</body>
</html>
